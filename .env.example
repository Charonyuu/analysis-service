# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/analytics

# 驗證
DASHBOARD_SECRET=your-super-secret-token-change-this

# 允許的來源網域（逗號分隔，完全比對）
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,https://charonyu.vercel.app

# 允許的來源網域 pattern（逗號分隔，支援 * wildcard）
ALLOWED_ORIGIN_PATTERNS=https://*.app.charonyu.cc

# Port
PORT=3000

# 環境
NODE_ENV=development

# PTT Proxy（透過 Cloudflare Worker 中繼，繞過 PTT 對 datacenter IP 的封鎖）
# PTT_PROXY_WORKER_URL=https://ptt-proxy.<your-subdomain>.workers.dev/
# PTT_PROXY_SECRET=lumee_ptt_proxy_s3cret
